# =============================================================================
# Sprintly — Environment Variables Template
# =============================================================================
#
# This file IS committed to git — it shows what variables are needed
# but contains no real secrets (all values are placeholders).
#
# Setup:
#   cp .env.example .env
#   Then edit .env with your actual values.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sprintly_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
DB_PORT=5432

# ── Spring Boot App ───────────────────────────────────────────────────────────
APP_PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=your_minimum_64_character_jwt_secret_key_here_change_this_value

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=default